# App
APP_NAME=template
NODE_ENV=development

# Ports
WEB_PORT=3000
API_PORT=3001

# Database (Postgres + pgvector)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/template

# Cache / queues
REDIS_URL=redis://localhost:6379

# Auth
# AUTH_METHOD options: email-password | magic-link | pki | pki-and-magic-link | google-oauth | other | none
AUTH_METHOD=email-password
BETTER_AUTH_SECRET=replace-with-32-byte-random-string
BETTER_AUTH_URL=http://localhost:3000
ADMIN_SEED_EMAIL=admin@example.com

# Additive sign-in options (valid when AUTH_METHOD=email-password).
# Accept "true"/"false". Both can be enabled at once.
AUTH_ENABLE_MAGIC_LINK=false
AUTH_ENABLE_ENTRA=false

# Microsoft Entra ID (Azure AD) OIDC — required when AUTH_ENABLE_ENTRA=true.
# Redirect URI to register in Azure: <BETTER_AUTH_URL>/api/auth/oauth2/callback/microsoft-entra-id
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# PKI / client-certificate auth (required when AUTH_METHOD includes "pki")
# Comma-separated IPs of reverse proxies trusted to forward cert headers.
# MUST be set and non-empty when PKI auth is enabled — leave blank for magic-link.
PKI_TRUSTED_PROXY_IPS=
PKI_SESSION_TTL_HOURS=8

# AI Providers
AI_DEFAULT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=

# Observability (Langfuse - stubbed unless both keys are present)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3030

# OpenTelemetry (optional — traces emitted only when endpoint is set)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=template-api

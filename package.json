{
  "name": "template",
  "version": "1.0.10",
  "private": true,
  "description": "Production-ready AI application monorepo template (hexagonal architecture).",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "db:generate": "pnpm --filter @rbrasier/adapters db:generate",
    "db:migrate": "pnpm --filter @rbrasier/adapters db:migrate",
    "db:check": "pnpm --filter @rbrasier/adapters db:check",
    "validate": "./validate.sh",
    "restart": "./restart.sh",
    "init": "./scripts/init-project.sh",
    "framework:update": "./scripts/update-framework.sh"
  },
  "pnpm": {
    "overrides": {
      "langsmith": ">=0.6.0",
      "vitest": ">=4 <5",
      "@vitest/coverage-v8": ">=4 <5",
      "vite": ">=6.4.3 <7",
      "better-auth": ">=1.6.11 <1.7",
      "@grpc/grpc-js": ">=1.14.4 <2",
      "protobufjs": ">=7.6.1"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "turbo": "^2.1.0",
    "typescript": "^5.6.0",
    "vite": "^6.4.3"
  }
}

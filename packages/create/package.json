{
  "name": "@template/create",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Scaffold a new project from the ai-app-template framework.",
  "bin": {
    "create-template": "./dist/index.js"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "prompts": "^2.4.2",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
